@page "/registration"

<div class="container mt-4">

    <!-- HEADER -->
    <div class="bg-primary text-white text-center p-3 fw-bold" style="font-size:20px;">
        Data Capturing System
    </div>

    <!-- MAIN BOX -->
    <div class="border p-4">

        <h5 class="fw-bold text-primary">Member Information</h5>
        <small class="text-muted">Member data is confidential and managed securely.</small>

        <div class="row mt-4">

            <!-- LEFT SIDE (STEP 1) -->
            <div class="col-md-6">

                <h6 class="fw-bold">Step 1</h6>
                <small class="text-muted">Personal Information *</small>

                <div class="row mt-3">

                    <div class="col-md-6 mb-3">
                        <label>First name *</label>
                        <InputText class="form-control" placeholder="Enter First Name" @bind-Value="model.FirstName" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Middle name *</label>
                        <InputText class="form-control" placeholder="Enter Middle Name" @bind-Value="model.MiddleName" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Last name *</label>
                        <InputText class="form-control" placeholder="Enter Last Name" @bind-Value="model.LastName" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Civil Status *</label>
                        <InputSelect class="form-control" @bind-Value="model.CivilStatus">
                            <option value="">Select Civil Status</option>
                            <option value="1">Single</option>
                            <option value="2">Married</option>
                            <option value="3">Divorced</option>
                            <option value="4">Widowed</option>
                        </InputSelect>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Date of Birth *</label>
                        <InputDate class="form-control" @bind-Value="model.DOB" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label>Gender *</label>
                        <InputSelect class="form-control" @bind-Value="model.Gender">
                            <option value="">Select Gender</option>
                            <option value="1">Male</option>
                            <option value="2">Female</option>
                            <option value="3"> Other</option>
                        </InputSelect>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label>Address</label>
                        <InputTextArea class="form-control" placeholder="Enter your complete address" @bind-Value="model.Address" />
                    </div>

                </div>
            </div>

            <!-- RIGHT SIDE (STEP 2) -->
            <div class="col-md-6">

                <h6 class="fw-bold">Step 2</h6>
                <small class="text-muted">Document Upload *</small>

                <!-- Upload Box -->
                <div class="border border-secondary mt-3 d-flex align-items-center justify-content-center"
                     style="height:180px; border-style:dashed;">
                    <span class="text-muted">Upload Area</span>
                </div>

                <!-- Instructions -->
                <div class="mt-3">
                    <small class="fw-bold">Photo Upload Instructions:</small>
                    <ul class="small text-muted">
                        <li>Upload a clear, recent photo of yourself.</li>
                        <li>Accepted formats: JPG, JPEG, or PNG.</li>
                        <li>Maximum file size: 5MB.</li>
                    </ul>
                </div>

               @*  <!-- Next Button -->
                <div class="text-end mt-4">
                    <button class="btn btn-primary px-4" @onclick="NextStep">
                        Next
                    </button>
                </div> *@

                <!-- Navigation Buttons -->
               

            </div>

        </div>
    </div>

    <div class="row">
        <div class="d-flex justify-content-between mt-4">
            <!-- Previous Button -->
            <button class="btn btn-secondary px-4" @onclick="PreviousStep">
                Previous
            </button>

            <!-- Next Button -->
            <button class="btn btn-primary px-4" @onclick="NextStep">
                Next
            </button>
        </div>
    </div>
    <br/>

</div>

@code {
    private RegisterModel model = new();

    void NextStep()
    {
        Console.WriteLine("Next clicked");
    }

    void PreviousStep()
    {
        Console.WriteLine("Previous Step clicked");
    }

    public class RegisterModel
    {
        public string FirstName { get; set; }
        public string MiddleName { get; set; }
        public string LastName { get; set; }
        public string CivilStatus { get; set; }
        public DateTime? DOB { get; set; }
        public string Gender { get; set; }
        public string Address { get; set; }
    }
}