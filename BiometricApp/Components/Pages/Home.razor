@page "/home"

<div class="registration-wrapper">
    <div class="overlay"></div>

    <div class="container h-100 d-flex align-items-center justify-content-center">
        <div class="content-box text-center">

            <img src="images/logo.jpg" class="logo mb-3" />

            <h2 class="fw-bold">Welcome to eRegistration Toolkit</h2>
            <p class="text-muted mb-4">Make a selection from the choices provided</p>

            <div class="row g-4 justify-content-center">

                <div class="col-md-4">
                    <NavLink href="/existing-nid" class="option-card">
                        <i class="bi bi-person-badge icon"></i>
                        <p>Existing NID Card Holder</p>
                    </NavLink>
                </div>

                <div class="col-md-4">
                    <NavLink href="/new-nid" class="option-card">
                        <i class="bi bi-person-plus icon"></i>
                        <p>New NID Application</p>
                    </NavLink>
                </div>

                <div class="col-md-4">
                    <NavLink href="/online-nid" class="option-card">
                        <i class="bi bi-file-earmark-text icon"></i>
                        <p>Online NID Application</p>
                    </NavLink>
                </div>

            </div>

        </div>
    </div>
</div>

<style>
    .registration-wrapper {
        position: relative;
        height: 100vh;
        background: url('/images/background.jpg') no-repeat center center;
        background-size: cover;
    }

    /* Light overlay */
    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(255,255,255,0.85);
    }

    /* Content Box */
    .content-box {
        position: relative;
        z-index: 2;
        max-width: 900px;
        width: 100%;
    }

    /* Logo */
    .logo {
        width: 80px;
    }

    /* Option Cards */
    .option-card {
        display: block;
        padding: 30px 20px;
        border-radius: 15px;
        background: #fff;
        border: 1px solid #d6d6d6;
        text-decoration: none;
        color: #333;
        transition: all 0.3s ease;
        box-shadow: 0 3px 8px rgba(0,0,0,0.05);
    }

        .option-card:hover {
            transform: translateY(-5px);
            border-color: #0d6efd;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

    /* Icon */
    .icon {
        font-size: 40px;
        margin-bottom: 10px;
        color: #555;
    }

    .option-card p {
        font-weight: 500;
        margin: 0;
    }
</style>




